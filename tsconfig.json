{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./client/*"] // Path alias for web app source
    }
  },
  "include": ["./client/**/*.ts", "./client/**/*.d.ts", "./client/**/*.tsx", "./client/**/*.js", "./client/**/*.jsx"],
  "exclude": ["./src", "node_modules", "dist"] // Exclude the 'src' directory as it contains the functions project
}