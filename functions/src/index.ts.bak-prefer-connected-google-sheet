}

export const startGoogleOAuth = onCall(
  {
    region: "us-central1",
    secrets: [
      GOOGLE_OAUTH_CLIENT_ID,
      GOOGLE_OAUTH_CLIENT_SECRET,
      GOOGLE_OAUTH_REDIRECT_URI,
    ],
  },
  async (request) => {
    const uid = requireAuth(request);
    const projectId = request.data?.projectId as string | undefined;

    if (!projectId) {
      throw new HttpsError("invalid-argument", "projectId is required.");
    }

    const stateId = randomUUID();

    await db.collection("oauthStates").doc(stateId).set({
      uid,
      projectId,
      createdAt: admin.firestore.FieldValue.serverTimestamp(),
    });

    const oauthClient = getOAuthClient();

    const url = oauthClient.generateAuthUrl({
      access_type: "offline",
      include_granted_scopes: true,
      prompt: "consent",
      scope: GOOGLE_SCOPES,
      state: stateId,
    });

    return {url};
  }
);

export const googleOAuthCallback = onRequest(
  {
    region: "us-central1",
    secrets: [
      GOOGLE_OAUTH_CLIENT_ID,
      GOOGLE_OAUTH_CLIENT_SECRET,
      GOOGLE_OAUTH_REDIRECT_URI,
    ],
  },
  async (req, res) => {
    try {
      const code = String(req.query.code || "");
      const stateId = String(req.query.state || "");

      if (!code || !stateId) {
        res.status(400).send("Missing OAuth code or state.");
        return;
      }

      const stateRef = db.collection("oauthStates").doc(stateId);
      const stateSnap = await stateRef.get();

      if (!stateSnap.exists) {
        res.status(400).send("Invalid OAuth state.");
        return;
      }

      const state = stateSnap.data() || {};
      const uid = state.uid;
      const projectId = state.projectId;

      const oauthClient = getOAuthClient();
      const tokenResponse = await oauthClient.getToken(code);
      const tokens = tokenResponse.tokens;

      oauthClient.setCredentials(tokens);

      const oauth2 = google.oauth2({
        version: "v2",
        auth: oauthClient,
      });

      const userInfo = await oauth2.userinfo.get();

      await db.collection("googleConnections").doc(uid).set(
        {
          uid,
          googleEmail: userInfo.data.email || "",
          refreshToken: tokens.refresh_token || "",
          scope: tokens.scope || "",
          connectedAt: admin.firestore.FieldValue.serverTimestamp(),
          updatedAt: admin.firestore.FieldValue.serverTimestamp(),
        },
        {merge: true}
      );

      await db.collection("projects").doc(projectId).set(
        {
          status: "google_connected",
          setupStep: "google_connected",
          googleConnected: true,
          googleEmail: userInfo.data.email || "",
          updatedAt: admin.firestore.FieldValue.serverTimestamp(),
        },
        {merge: true}
      );

      await stateRef.delete();

      res.redirect(
        `https://unscriptly.web.app/?projectId=${encodeURIComponent(
          projectId
        )}&setupPage=google&googleConnected=1`
      );
    } catch (error: any) {
      res.status(500).send(error.message || "OAuth failed.");
    }
  }
);

const isMockGoogleId = (value?: string): boolean => {
  return Boolean(
    value &&
      (value.includes("mock-") ||
        value === "mock-google-sheet-id" ||
        value === "mock-apps-script-project-id")
  );
};

export const runRealSync = onCall(
  {
    region: "us-central1",
    timeoutSeconds: 300,
    memory: "1GiB",
    secrets: [
      GOOGLE_OAUTH_CLIENT_ID,
      GOOGLE_OAUTH_CLIENT_SECRET,
      GOOGLE_OAUTH_REDIRECT_URI,
    ],
  },
  async (request) => {
    const uid = requireAuth(request);
    const projectId = request.data?.projectId as string | undefined;

    if (!projectId) {
      throw new HttpsError("invalid-argument", "projectId is required.");
    }

    const projectRef = db.collection("projects").doc(projectId);
    const projectSnap = await projectRef.get();

    if (!projectSnap.exists) {
      throw new HttpsError("not-found", "Project not found.");
    }

    const project = projectSnap.data() || {};

    if (project.ownerUserId !== uid && project.createdByUid !== uid) {
      throw new HttpsError("permission-denied", "You do not own this project.");
    }

    const auth = await getGoogleClientForUser(uid);

    const sheets = google.sheets({version: "v4", auth});
    const script = google.script({version: "v1", auth});

    const businessName = project.businessName || "UnScriptly";
    const spreadsheetTitle =
      project.spreadsheetName || `${businessName} - UnScriptly Operations`;

    let spreadsheetId =
        isMockGoogleId(project.spreadsheetId) || isMockGoogleId(project.googleSheetId) ?
          "" :
          project.spreadsheetId || project.googleSheetId || "";
    let spreadsheetUrl =
        project.spreadsheetUrl || project.googleSheetUrl || "";

    if (!spreadsheetId) {
      const createdSpreadsheet = await sheets.spreadsheets.create({
        requestBody: {
          properties: {title: spreadsheetTitle},
          sheets: [
            {properties: {title: "Leads"}},
            ...getSystemTabs().map((title) => ({properties: {title}})),
          ],
        },
      });

      spreadsheetId = createdSpreadsheet.data.spreadsheetId || "";
      spreadsheetUrl = createdSpreadsheet.data.spreadsheetUrl || "";
    }

    const spreadsheet = await sheets.spreadsheets.get({
      spreadsheetId,
      includeGridData: false,
    });

    const existingSheets =
      spreadsheet.data.sheets?.map((sheet) => sheet.properties?.title || "") || [];

    const neededTabs = ["Leads", ...getSystemTabs()];
    const missingTabs = neededTabs.filter((tab) => !existingSheets.includes(tab));

    if (missingTabs.length > 0) {
      await sheets.spreadsheets.batchUpdate({
        spreadsheetId,
        requestBody: {
          requests: missingTabs.map((title) => ({
            addSheet: {properties: {title}},
          })),
        },
      });
    }

    const headers = getLeadHeaders();

    const headerRead = await sheets.spreadsheets.values.get({
      spreadsheetId,
      range: "Leads!1:1",
    });

    const existingHeaders =
      headerRead.data.values && headerRead.data.values.length > 0 ?
        headerRead.data.values[0] :
        [];

    const missingHeaders = headers.filter(
      (header) => !existingHeaders.includes(header)
    );

    const finalHeaders = [...existingHeaders, ...missingHeaders];

    await sheets.spreadsheets.values.update({
      spreadsheetId,
      range: `Leads!A1:${columnLetter(finalHeaders.length)}1`,
      valueInputOption: "RAW",
      requestBody: {values: [finalHeaders]},
    });

    let scriptId =
        isMockGoogleId(project.scriptProjectId) || isMockGoogleId(project.appsScriptProjectId) ?
          "" :
          project.scriptProjectId || project.appsScriptProjectId || "";
    let scriptProjectName =
        project.scriptProjectName || project.appsScriptProjectName || "";

    if (!scriptId) {
      const createdScriptProject = await script.projects.create({
        requestBody: {
          title: `UnScriptly - ${businessName}`,
          parentId: spreadsheetId,
        },
      });

      scriptId = createdScriptProject.data.scriptId || "";
      scriptProjectName =
        createdScriptProject.data.title || `UnScriptly - ${businessName}`;
    }

    const appsScriptFiles = generateAppsScriptFiles("Leads");

    await script.projects.updateContent({
      scriptId,
      requestBody: {
        files: appsScriptFiles as any,
      },
    });

    const syncRunId = `${projectId}_${Date.now()}`;

    await db.collection("schemaSnapshots").doc(`${projectId}_latest`).set({
      projectId,
      snapshotType: "real_google_sync_schema",
      spreadsheetId,
      spreadsheetUrl,
      tabs: neededTabs,
      leadsHeaders: finalHeaders,
      addedTabs: missingTabs,
      addedHeaders: missingHeaders,
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    });

    await db.collection("scriptSnapshots").doc(`${projectId}_latest`).set({
      projectId,
      snapshotType: "real_google_sync_script",
      scriptId,
      scriptProjectName,
      fileCount: appsScriptFiles.length,
      files: appsScriptFiles,
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    });

    await db.collection("syncRuns").doc(syncRunId).set({
      projectId,
      runType: "real_google_sync",
      status: "completed",
      touchedGoogleSheets: true,
      touchedAppsScript: true,
      spreadsheetId,
      spreadsheetUrl,
      scriptId,
      scriptProjectName,
      addedTabs: missingTabs,
      addedHeaders: missingHeaders,
      generatedAppsScriptFiles: appsScriptFiles.map((file) => file.name),
      createdAt: admin.firestore.FieldValue.serverTimestamp(),
      updatedAt: admin.firestore.FieldValue.serverTimestamp(),
    });

    await projectRef.set(
      {
        status: "synced",
        setupStep: "synced_real",
        spreadsheetId,
        spreadsheetName: spreadsheetTitle,
        spreadsheetUrl,
        scriptProjectId: scriptId,
        scriptProjectName,
        appsScriptProjectId: scriptId,
        appsScriptProjectName: scriptProjectName,
        appsScriptUrl: scriptId ? `https://script.google.com/home/projects/${scriptId}/edit` : "",
        lastSyncRunId: syncRunId,
        syncedAt: admin.firestore.FieldValue.serverTimestamp(),
        updatedAt: admin.firestore.FieldValue.serverTimestamp(),
      },
      {merge: true}
    );

    return {
      ok: true,
      syncRunId,
      spreadsheetId,
      spreadsheetUrl,
      scriptId,
      scriptProjectName,
      addedTabs: missingTabs,
      addedHeaders: missingHeaders,
    };
  }
);
